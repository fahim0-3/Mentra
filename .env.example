# ===========================================================================
#  Mentra — environment variables (reference)
#
#  Mentra reads these from your OS environment; it does NOT auto-load a .env
#  file. Set them in PowerShell, for example:
#
#    [Environment]::SetEnvironmentVariable("GROQ_API_KEY", "your_key", "User")
#
#  This file only documents the supported variables — do NOT put real keys in
#  it (and never commit real keys; `.env` is gitignored).
# ===========================================================================

# Groq Cloud API key — enables fast, accurate ONLINE meeting transcription
# (whisper-large-v3-turbo) and answers (llama-3.1-8b-instant).
# Get a free key at https://console.groq.com
# Leave unset to use the fully offline local fallback (faster-whisper + Ollama).
GROQ_API_KEY=

# Optional. Set to "1" to use the Silero ONNX VAD instead of the default
# energy-based VAD. Requires a silero_vad.onnx model under mentra/workers/models/;
# if absent, Mentra falls back to the energy VAD automatically.
MENTRA_USE_SILERO=
